<resources>
    <style name="TagEditor"/>

    <style name="Widget.TagMo.Card.Surface" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/ui_surface</item>
        <item name="cardCornerRadius">@dimen/list_card_radius</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeColor">@color/ui_outline</item>
        <item name="strokeWidth">1dp</item>
        <item name="rippleColor">@color/highlightWhite</item>
    </style>

    <style name="Widget.TagMo.Card.Menu" parent="Widget.TagMo.Card.Surface">
        <item name="cardCornerRadius">@dimen/menu_card_radius</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="Widget.TagMo.Button.Filled" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/rounded_button</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:paddingLeft">18dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingRight">18dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="TextAppearance.TagMo.Title" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/tag_text</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TextAppearance.TagMo.Meta" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/ui_meta_text</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="TextAppearance.TagMo.DrawerLabel" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/tag_text</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TagEditor.InputHint" parent="TextAppearance.Design.Hint">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingLeft">4dp</item>
        <item name="android:paddingRight">4dp</item>
        <item name="android:textColor">?android:textColorHint</item>
    </style>

    <style name="TagEditor.Spinner" parent="Widget.AppCompat.Spinner.Underlined">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="TagEditor.EditDate">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:focusable">false</item>
        <item name="android:inputType">date</item>
        <item name="android:longClickable">false</item>
        <item name="android:maxLines">1</item>
    </style>

    <style name="TagEditor.EditNumber">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">right</item>
        <item name="android:inputType">numberSigned</item>
        <item name="android:maxLines">1</item>
        <item name="android:selectAllOnFocus">true</item>
    </style>

    <style name="TagEditor.EditHex">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:inputType">textCapCharacters|textNoSuggestions</item>
        <item name="android:maxLines">1</item>
        <item name="android:singleLine">true</item>
    </style>

    <style name="TagEditor.EditSerial">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">right</item>
        <item name="android:inputType">textCapCharacters|textNoSuggestions</item>
        <item name="android:maxLines">1</item>
        <item name="android:singleLine">true</item>
    </style>

    <style name="TagEditor.Header">
        <item name="android:background">@drawable/light_header_dither</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?android:textColorSecondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingLeft">6dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="TagEditor.Header.NoBackground" parent="TagEditor.Header">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@null</item>
        <item name="android:paddingLeft">0dp</item>
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingRight">0dp</item>
        <item name="android:paddingEnd">0dp</item>
    </style>

    <style name="WearTabText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">10sp</item>
    </style>

    <style name="SlimButton" parent="Widget.AppCompat.Button.Small">
        <item name="android:minHeight">@dimen/button_height_min</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
